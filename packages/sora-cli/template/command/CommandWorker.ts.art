import {<%- workerNameEnum %>} from '<%- workerNameWorkerRelativePath %>';
import {IWorkerOptions, Node, Worker} from '@sora-soft/framework';
import typia from 'typia';

export interface I<%- upperCamelCaseWorkerName %>CommandWorkerOptions extends IWorkerOptions {
}

class <%- upperCamelCaseWorkerName %>CommandWorker extends Worker {
