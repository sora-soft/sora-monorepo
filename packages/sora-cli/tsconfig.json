{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "ignoreDeprecations": "5.0",
    "verbatimModuleSyntax": false,
    "outDir": "./dist",
    "rootDir": "./src",
    "target": "ESNext",
    "resolveJsonModule": true,
    "alwaysStrict": true,
    "downlevelIteration": true,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "plugins": []
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
