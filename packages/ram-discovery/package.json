{
  "name": "@sora-soft/ram-discovery",
  "version": "1.0.2",
  "description": "sora system ram discovery",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "npm run clean && tspc",
    "clean": "rimraf ./dist",
    "prepublishOnly": "tspc",
