{
  "compilerOptions": {
    "target": "ES2022",
    "module": "node16",
    "moduleResolution": "node16",
    "lib": ["ESNext"],
    "types": ["node"],

    "strict": true,
    "verbatimModuleSyntax": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,

    "outDir": "../../dist/transformer",
    "rootDir": "./",
    "declaration": true,
    "sourceMap": true,

    "skipLibCheck": true,
    "incremental": false,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["./*"],
  "exclude": []
}
