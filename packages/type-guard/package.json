{
  "name": "@sora-soft/type-guard",
  "version": "2.0.1",
  "description": "",
  "main": "./dist/runtime/index.js",
  "types": "./dist/runtime/index.d.ts",
  "scripts": {
    "build": "rimraf ./dist && tsc --project ./src/runtime/tsconfig.json && tsc --project ./src/transformer/tsconfig.json && copyfiles -f ./src/transformer/package.json ./dist/transformer",
    "clean": "rimraf ./dist",
    "prepublishOnly": "npm run build",
    "prepare": "npx husky install",
    "preversion": "lint-staged && npm run build",
    "preCommit": "lint-staged"
  },
  "repository": "git@github.com:sora-soft/type-guard.git",
  "type": "module",
  "keywords": [
    "sora",
    "type-guard"
  ],
  "author": "yaya",
  "license": "WTFPL",
  "lint-staged": {
    "*.ts": [
      "eslint"
    ]
  },
  "devDependencies": {
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/node": "^24.0.0",
    "@types/object-hash": "^3.0.6",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "copyfiles": "^2.4.1",
    "eslint": "^9.39.4",
    "husky": "^8.0.3",
    "lint-staged": "^13.1.2",
    "rimraf": "^3.0.2",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "ajv": "^8.12.0",
    "object-hash": "^3.0.0",
    "path-equal": "^1.1.2",
    "reflect-metadata": "^0.2.2",
    "source-map-support": "^0.5.21"
  }
}
